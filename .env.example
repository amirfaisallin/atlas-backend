OANDA_TOKEN=your_oanda_bearer_token
VITE_OANDA_TOKEN=your_oanda_bearer_token
API_PORT=3001

# MongoDB – ইউজার ও ট্রেড ডেটা সেভ হয় (JSON ডকুমেন্ট)। Heroku এ Config Vars এ MONGODB_URI সেট করুন।
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
# Optional: database name (default: altrix)
# MONGODB_DB_NAME=altrix

# Cloudinary – ডিপোজিট স্ক্রিনশট ও ভেরিফিকেশন ইমেজ সেভ হয় (MongoDB তে base64 সেভ হয় না)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# অথবা একসাথে: CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
